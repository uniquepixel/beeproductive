<?xml version="1.0" encoding="utf-8"?>
<!-- Cloned by AI (new layout for the swarm showcase): honey texture background, the bees fly in
     the container above it, and the two control sliders sit at the bottom of the screen. Uses
     only stock android widgets so a fresh project needs no extra dependencies. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/showcase_honey_background">

    <!-- The bees (and the permanent swipe-and-disperse layer) live in here -->
    <FrameLayout
        android:id="@+id/beeContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Control bar at the bottom of the screen (on top of the swipe layer in z-order,
         so slider touches never reach the swarm) -->
    <LinearLayout
        android:id="@+id/controlPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#B32B2B2B"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="12dp"
        android:paddingBottom="20dp">

        <TextView
            android:id="@+id/swarmSizeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Swarm size: 12"
            android:textColor="#FFD700"
            android:textSize="14sp" />

        <SeekBar
            android:id="@+id/swarmSizeSlider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="40"
            android:progress="12" />

        <TextView
            android:id="@+id/angrinessLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Angriness: 20%"
            android:textColor="#FFD700"
            android:textSize="14sp" />

        <SeekBar
            android:id="@+id/angrinessSlider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="20" />
    </LinearLayout>

</FrameLayout>
