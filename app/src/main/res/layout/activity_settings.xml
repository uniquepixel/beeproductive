<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/settings_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bee_soft_yellow"
    android:clipChildren="false"
    tools:context=".frontend.SettingsActivity">

    <!-- Subtle Hexagon Background Pattern (Consistent with Main) -->
    <ImageView
        android:layout_width="350dp"
        android:layout_height="350dp"
        android:layout_marginStart="-120dp"
        android:layout_marginTop="-80dp"
        android:alpha="0.2"
        android:rotation="15"
        android:src="@drawable/ic_hexagon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_marginStart="-100dp"
        android:layout_marginBottom="100dp"
        android:alpha="0.18"
        android:rotation="40"
        android:src="@drawable/ic_hexagon"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_marginEnd="-40dp"
        android:layout_marginBottom="-40dp"
        android:alpha="0.2"
        android:rotation="10"
        android:src="@drawable/ic_hexagon"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:padding="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/settingsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:layout_marginBottom="64dp"
                android:fontFamily="sans-serif-black"
                android:text="Settings"
                android:textColor="@color/bee_dark"
                android:textSize="48sp" />

            <!-- Example Button 1 -->
            <com.google.android.material.button.MaterialButton
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:text="Your Stats"
                android:textAlignment="viewStart"
                android:textColor="@color/bee_dark"
                android:textSize="18sp"
                app:icon="@drawable/ic_hexagon"
                app:iconSize="18dp"
                app:iconTint="@color/bee_yellow" />

            <!-- Fancy Divider 1 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_marginHorizontal="8dp"
                android:layout_marginVertical="8dp"
                android:alpha="0.3"
                android:background="@drawable/divider_bee_line" />

            <!-- Example Button 2 -->
            <com.google.android.material.button.MaterialButton
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:text="Notifications"
                android:textAlignment="viewStart"
                android:textColor="@color/bee_dark"
                android:textSize="18sp"
                app:icon="@drawable/ic_hexagon"
                app:iconSize="18dp"
                app:iconTint="@color/bee_yellow" />

            <!-- Fancy Divider 2 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_marginHorizontal="8dp"
                android:layout_marginVertical="8dp"
                android:alpha="0.3"
                android:background="@drawable/divider_bee_line" />

            <!-- Example Button 3 -->
            <com.google.android.material.button.MaterialButton
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:text="Productivity Settings"
                android:textAlignment="viewStart"
                android:textColor="@color/bee_dark"
                android:textSize="18sp"
                app:icon="@drawable/ic_hexagon"
                app:iconSize="18dp"
                app:iconTint="@color/bee_yellow" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/backButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="64dp"
                android:text="Back to Main"
                android:textColor="@color/bee_dark"
                app:backgroundTint="@color/bee_yellow" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>