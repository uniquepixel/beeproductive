<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/settings_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bee_soft_yellow"
    android:clipChildren="false"
    tools:context=".frontend.SettingsActivity">

    <!-- Subtle Hexagon Background Pattern -->
    <ImageView
        android:layout_width="350dp"
        android:layout_height="350dp"
        android:layout_marginStart="-120dp"
        android:layout_marginTop="-80dp"
        android:alpha="0.2"
        android:rotation="15"
        android:src="@drawable/ic_hexagon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_marginStart="-100dp"
        android:layout_marginBottom="100dp"
        android:alpha="0.18"
        android:rotation="40"
        android:src="@drawable/ic_hexagon"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_marginEnd="-40dp"
        android:layout_marginBottom="-40dp"
        android:alpha="0.2"
        android:rotation="10"
        android:src="@drawable/ic_hexagon"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:padding="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/settingsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:layout_marginBottom="48dp"
                android:fontFamily="sans-serif-black"
                android:text="Settings"
                android:textColor="@color/bee_dark"
                android:textSize="48sp" />

            <!-- Swarm Aggression Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_swarm_aggression"
                    android:textColor="@color/bee_dark"
                    android:textSize="18sp"
                    android:textStyle="bold" />
                
                <com.google.android.material.slider.Slider
                    android:id="@+id/aggressionSlider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="1.0"
                    android:valueTo="60.0"
                    android:stepSize="1.0"
                    app:thumbColor="@color/bee_yellow"
                    app:trackColorActive="@color/bee_yellow" />
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:text="Fast ->"
                    android:textColor="@color/bee_dark"
                    android:alpha="0.6"
                    android:textSize="12sp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_marginHorizontal="8dp"
                android:layout_marginVertical="16dp"
                android:alpha="0.3"
                android:background="@drawable/divider_bee_line" />

            <!-- Swarm Size Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_swarm_size"
                    android:textColor="@color/bee_dark"
                    android:textSize="18sp"
                    android:textStyle="bold" />
                
                <com.google.android.material.slider.Slider
                    android:id="@+id/sizeSlider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="1.0"
                    android:valueTo="100.0"
                    android:stepSize="1.0"
                    app:thumbColor="@color/bee_yellow"
                    app:trackColorActive="@color/bee_yellow" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_marginHorizontal="8dp"
                android:layout_marginVertical="16dp"
                android:alpha="0.3"
                android:background="@drawable/divider_bee_line" />

            <!-- Reset Categorization Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/resetCategorizationButton"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:text="@string/reset_categorizations"
                android:textAlignment="viewStart"
                android:textColor="@color/bee_dark"
                android:textSize="18sp"
                app:icon="@drawable/ic_hexagon"
                app:iconSize="18dp"
                app:iconTint="@color/bee_yellow" />

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_marginHorizontal="8dp"
                android:layout_marginVertical="8dp"
                android:alpha="0.3"
                android:background="@drawable/divider_bee_line" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/backButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:text="Back to Main"
                android:textColor="@color/bee_dark"
                app:backgroundTint="@color/bee_yellow" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>