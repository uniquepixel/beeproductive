<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bee_soft_yellow"
    android:clipChildren="false">

    <ImageView
        android:layout_width="350dp"
        android:layout_height="350dp"
        android:layout_marginStart="-120dp"
        android:layout_marginTop="-80dp"
        android:alpha="0.2"
        android:rotation="15"
        android:src="@drawable/ic_hexagon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_marginEnd="-60dp"
        android:layout_marginTop="120dp"
        android:alpha="0.15"
        android:rotation="-20"
        android:src="@drawable/ic_hexagon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_marginStart="-100dp"
        android:layout_marginBottom="100dp"
        android:alpha="0.18"
        android:rotation="40"
        android:src="@drawable/ic_hexagon"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_marginEnd="-40dp"
        android:layout_marginBottom="-40dp"
        android:alpha="0.2"
        android:rotation="10"
        android:src="@drawable/ic_hexagon"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <ImageView
        android:id="@+id/lastActivityScreenshot"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="40dp"
        android:alpha="0.8"
        android:scaleType="centerInside"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/interventionTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:fontFamily="sans-serif-black"
        android:text="The Queen Bee says no"
        android:textColor="@color/bee_dark"
        android:textSize="32sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Caption for the screenshot evidence the Queen holds up (AI generated) -->
    <TextView
        android:id="@+id/screenshotCaption"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginTop="4dp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:textStyle="italic"
        android:text=""
        android:textColor="@color/bee_dark"
        android:textSize="13sp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/interventionTitle" />


    <com.google.android.material.card.MaterialCardView
        android:id="@+id/chatContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="24dp"
        app:cardBackgroundColor="#CCFFFFFF"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toTopOf="@+id/inputContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/screenshotCaption"
        app:strokeColor="@color/bee_yellow"
        app:strokeWidth="2dp">

        <TextView
            android:id="@+id/chatMessageDisplay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="20dp"
            android:text="This is where Chat messages will go. Defend yourself!"
            android:textColor="@color/bee_dark"
            android:textSize="18sp" />
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/inputContainer"
        android:layout_width="0dp"
        android:layout_height="140dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="24dp"
        app:cardBackgroundColor="@color/bee_dark"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <EditText
                android:id="@+id/chatEditText"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:gravity="top"
                android:hint="Chat with the Queen!"
                android:imeOptions="actionSend"
                android:inputType="textMultiLine"
                android:padding="12dp"
                android:textColor="@android:color/white"
                android:textColorHint="#A0FFFFFF"
                android:textSize="16sp" />

            <ImageButton
                android:id="@+id/sendButton"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="bottom"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_send"
                app:tint="@color/bee_yellow" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>


    <ImageView
        android:id="@+id/queenBeeIcon"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_marginEnd="0dp"
        android:layout_marginBottom="40dp"
        android:src="@drawable/queen_asking"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:elevation="10dp"
        />

    <!-- Verdict banner: pops in when the Queen has made her decision (AI generated) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/decisionBanner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:elevation="12dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/decision_refill"
        app:cardCornerRadius="20dp"
        app:cardElevation="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.32">

        <TextView
            android:id="@+id/decisionBannerText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:text="Verdict"
            android:textColor="@color/white"
            android:textSize="24sp" />
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
